{
  "name": "antani",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "ANTANI_DEV=1 tauri dev --config src-tauri/tauri.conf.dev.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --ignore-filename-regex 'git_watcher\\.rs|ide_webview\\.rs|lib\\.rs|main\\.rs|pty\\.rs|vscode_server\\.rs' --fail-under-lines 90",
    "prepare": "husky && sh scripts/setup-rust-tools.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@xterm/addon-canvas": "0.7.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "knip": "6.25.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.8.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
